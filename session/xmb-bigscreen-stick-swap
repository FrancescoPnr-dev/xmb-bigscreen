# Generates the per-controller SDL mapping for the Bigscreen input handler and
# is run automatically at every XMB session login. Triangle always emits the
# Games key (toggles the XMB search; the Menu key won't do — the native
# Bigscreen homescreen leaves a global shortcut on it) and Square keeps the
# Menu key (deletes in the on-screen keyboard); the analog sticks are swapped
# (pointer on the left, list navigation on the right, L3 as click) only when
# enabled from the XMB settings or with --on. Only the input handler's systemd
# unit loads the file, so games keep the physical layout.
import ctypes
import os
import sys

CONF_DIR = os.path.join(os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")),
                        "xmb-bigscreen")
CONFIG = os.path.join(CONF_DIR, "gamecontroller-swap.txt")
FLAG = os.path.join(CONF_DIR, "stickswap")
BUTTONS = {"y": "start", "start": "y"}
STICKS = {"leftx": "rightx", "rightx": "leftx", "lefty": "righty", "righty": "lefty",
          "leftstick": "rightstick", "rightstick": "leftstick"}


class SDL_GUID(ctypes.Structure):
    _fields_ = [("data", ctypes.c_uint8 * 16)]


def connected_mappings(swap_sticks):
    try:
        sdl = ctypes.CDLL("libSDL3.so.0")
    except OSError:
        sys.exit("libSDL3 not found; install sdl3 (plasma-bigscreen needs it too)")
    sdl.SDL_Init.argtypes = [ctypes.c_uint32]
    sdl.SDL_Init.restype = ctypes.c_bool
    sdl.SDL_GetGamepads.argtypes = [ctypes.POINTER(ctypes.c_int)]
    sdl.SDL_GetGamepads.restype = ctypes.POINTER(ctypes.c_uint32)
    sdl.SDL_GetGamepadGUIDForID.argtypes = [ctypes.c_uint32]
    sdl.SDL_GetGamepadGUIDForID.restype = SDL_GUID
    sdl.SDL_GetGamepadMappingForGUID.argtypes = [SDL_GUID]
    sdl.SDL_GetGamepadMappingForGUID.restype = ctypes.c_char_p
    sdl.SDL_GetGamepadNameForID.argtypes = [ctypes.c_uint32]
    sdl.SDL_GetGamepadNameForID.restype = ctypes.c_char_p
    if not sdl.SDL_Init(0x00002000):  # SDL_INIT_GAMEPAD
        sys.exit("SDL_Init failed")
    swap = dict(BUTTONS)
    if swap_sticks:
        swap.update(STICKS)
    count = ctypes.c_int(0)
    ids = sdl.SDL_GetGamepads(ctypes.byref(count))
    result = {}
    for i in range(count.value):
        jid = ids[i]
        mapping = sdl.SDL_GetGamepadMappingForGUID(sdl.SDL_GetGamepadGUIDForID(jid))
        if not mapping:
            continue
        name = (sdl.SDL_GetGamepadNameForID(jid) or b"?").decode()
        parts = []
        for p in mapping.decode().split(","):
            k, sep, v = p.partition(":")
            parts.append(swap[k] + ":" + v if sep and k in swap else p)
        result[parts[0]] = (name, ",".join(parts))
    return result


def regenerate(swap_sticks):
    new = connected_mappings(swap_sticks)
    if not new:
        print("No gamepad connected; mappings refresh at the next session login")
        return
    existing = {}
    if os.path.exists(CONFIG):
        for line in open(CONFIG, encoding="utf-8"):
            line = line.strip()
            if line and not line.startswith("#"):
                existing[line.split(",", 1)[0]] = line
    for guid, (name, mapping) in new.items():
        existing[guid] = mapping
        print("wrote pad mapping for:", name, "(" + guid + ")")
    os.makedirs(CONF_DIR, exist_ok=True)
    with open(CONFIG, "w", encoding="utf-8") as f:
        f.write("# Generated by xmb-bigscreen-stick-swap - do not edit.\n")
        f.write("\n".join(existing.values()) + "\n")
    print("saved to", CONFIG, "- sticks", "swapped" if swap_sticks else "physical")


if __name__ == "__main__":
    arg = sys.argv[1] if len(sys.argv) > 1 else ""
    if arg == "--on":
        os.makedirs(CONF_DIR, exist_ok=True)
        open(FLAG, "w").close()
        regenerate(True)
    elif arg == "--off":
        if os.path.exists(FLAG):
            os.remove(FLAG)
        regenerate(False)
    elif arg == "":
        regenerate(os.path.exists(FLAG))
    else:
        print("usage: xmb-bigscreen-stick-swap [--on|--off]")
        print("  --on/--off set the stick-swap preference; no argument refreshes")
        print("  the mappings of the connected controllers with the saved one.")
        sys.exit(2)
