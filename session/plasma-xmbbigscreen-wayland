# WirePlumber keeps one per-user audio state (volumes, mutes, default device), so the
# TV and desktop sessions would trample each other's. Give each its own persistent
# slot and swap them around the session; the parked desktop slot doubles as the
# crash marker, so an unclean exit heals on the next swap.
wp_state="${XDG_STATE_HOME:-$HOME/.local/state}/wireplumber"
wp_desktop="$wp_state.desktop-session"
wp_xmb="$wp_state.xmb-session"

audio_state_enter() {
    # Desktop slot already parked = crashed XMB run; its live state is already ours.
    if [ ! -d "$wp_desktop" ]; then
        systemctl --user stop wireplumber 2>/dev/null
        sleep 2
        [ -d "$wp_state" ] && mv "$wp_state" "$wp_desktop"
        if [ -d "$wp_xmb" ]; then
            mv "$wp_xmb" "$wp_state"
        elif [ -d "$wp_desktop" ]; then
            # First TV login: seed from the desktop so devices and volumes start sane.
            cp -a "$wp_desktop" "$wp_state"
        fi
        systemctl --user start wireplumber 2>/dev/null
    fi
}

audio_state_exit() {
    systemctl --user stop wireplumber 2>/dev/null
    rm -rf "$wp_xmb"
    [ -d "$wp_state" ] && mv "$wp_state" "$wp_xmb"
    [ -d "$wp_desktop" ] && mv "$wp_desktop" "$wp_state"
    # Restart only after the logout churn settles: a USB DAC re-probed too early loses
    # its analog profile. The transient timer outlives this session; if the whole user
    # manager goes down with it, the next login starts wireplumber fresh anyway.
    systemd-run --user --on-active=5 systemctl --user start wireplumber 2>/dev/null \
        || systemctl --user start wireplumber 2>/dev/null
}

stop_stale_inputhandlers() {
    # An input handler leaked from an earlier session keeps the gamepad bound to a
    # dead compositor and starves the new session's instance.
    systemctl --user stop 'app-org.kde.plasma.bigscreen.inputhandler@*.service' 2>/dev/null
}

stop_stale_inputhandlers
audio_state_enter

# Refresh the pad mappings for the controllers present at login: the search keys
# work out of the box, sticks swapped only if enabled in the XMB settings.
xmb-bigscreen-stick-swap >/dev/null 2>&1 || true

# Reuse Bigscreen's environment, then load our shell instead of the native one.
. plasma-bigscreen-common-env
export PLASMA_DEFAULT_SHELL=org.kde.plasma.xmbbigscreen

# Bigscreen forces the compositor keyboard (plasma-keyboard, if installed) onto
# every focused text field. Drop the override: the XMB brings its own gamepad
# keyboard, and apps get the compositor one per KWin's normal rules.
unset KWIN_IM_SHOW_ALWAYS

# TV defaults regardless of the desktop session's kwinrc: one virtual desktop, no
# hot edges or corners. The [$i] locks apply only through this session's
# XDG_CONFIG_DIRS cascade; the shared ~/.config/kwinrc is never touched.
xmb_conf="${XDG_CONFIG_HOME:-$HOME/.config}/xmb-bigscreen"
mkdir -p "$xmb_conf"
cat > "$xmb_conf/kwinrc" <<'EOF'
[Desktops]
Number[$i]=1
Rows[$i]=1

[Windows]
ElectricBorders[$i]=0

[ElectricBorders]
Bottom[$i]=None
BottomLeft[$i]=None
BottomRight[$i]=None
Left[$i]=None
Right[$i]=None
Top[$i]=None
TopLeft[$i]=None
TopRight[$i]=None

[TouchEdges]
Bottom[$i]=none
Left[$i]=none
Right[$i]=none
Top[$i]=none

[Effect-overview]
BorderActivate[$i]=9

[Effect-windowview]
BorderActivate[$i]=9
BorderActivateAll[$i]=9

[TabBox]
BorderActivate[$i]=9
BorderAlternativeActivate[$i]=9
EOF

# Icon theme chosen in the XMB settings (a plain theme id, if any): pin it into the
# session-only cascade as an immutable key so it wins over the shared kdeglobals
# without ever touching the desktop's theme. Empty/missing = system default.
xmb_icons="$xmb_conf/icontheme"
rm -f "$xmb_conf/kdeglobals"
if [ -r "$xmb_icons" ]; then
    theme=$(head -n1 "$xmb_icons" 2>/dev/null | tr -cd 'A-Za-z0-9_.+-')
    [ -n "$theme" ] && printf '[Icons]\nTheme[$i]=%s\n' "$theme" > "$xmb_conf/kdeglobals"
fi
export XDG_CONFIG_DIRS="$xmb_conf:$XDG_CONFIG_DIRS"

startplasma-wayland --xwayland --libinput --exit-with-session=/usr/lib/startplasma-waylandsession

audio_state_exit
stop_stale_inputhandlers
