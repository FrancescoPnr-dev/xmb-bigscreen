# WirePlumber keeps one per-user audio state: give each session its own slot and
# swap on enter/exit; the parked desktop slot doubles as the crash marker.
wp_state="${XDG_STATE_HOME:-$HOME/.local/state}/wireplumber"
wp_desktop="$wp_state.desktop-session"
wp_xmb="$wp_state.xmb-session"

audio_state_enter() {
    # Desktop slot already parked = crashed XMB run; its live state is already ours.
    if [ ! -d "$wp_desktop" ]; then
        systemctl --user stop wireplumber 2>/dev/null
        sleep 2
        [ -d "$wp_state" ] && mv "$wp_state" "$wp_desktop"
        if [ -d "$wp_xmb" ]; then
            mv "$wp_xmb" "$wp_state"
        elif [ -d "$wp_desktop" ]; then
            # First TV login: seed from the desktop so devices and volumes start sane,
            # but never inherit muted notification sounds - they carry the XMB ticks.
            cp -a "$wp_desktop" "$wp_state"
            sed -i '/media.role:Notification/s/"mute":true/"mute":false/' \
                "$wp_state/stream-properties" 2>/dev/null || true
        fi
        systemctl --user start wireplumber 2>/dev/null
    fi
}

audio_state_exit() {
    # No parked desktop slot = enter never swapped (or we already unwound):
    # swapping now would shove the desktop state into the XMB slot, so hands off.
    [ -d "$wp_desktop" ] || return 0
    systemctl --user stop wireplumber 2>/dev/null
    # A crash mid-enter can leave no live dir; the parked XMB slot is then the
    # only copy of the XMB state, so overwrite it only when there is a live dir.
    if [ -d "$wp_state" ]; then
        rm -rf "$wp_xmb"
        mv "$wp_state" "$wp_xmb"
    fi
    mv "$wp_desktop" "$wp_state"
    # Restart only after the logout churn settles: a USB DAC re-probed too early
    # loses its analog profile. A dead user manager just means a fresh start instead.
    systemd-run --user --on-active=5 systemctl --user start wireplumber 2>/dev/null \
        || systemctl --user start wireplumber 2>/dev/null
}

stop_stale_inputhandlers() {
    # An input handler leaked from an earlier session keeps the gamepad bound to a
    # dead compositor and starves the new session's instance.
    systemctl --user stop 'app-org.kde.plasma.bigscreen.inputhandler@*.service' 2>/dev/null
}

audio_wait_ready() {
    # Wait for real sinks: if plasmashell starts while only the dummy output exists,
    # QtMultimedia binds to nothing and the XMB sounds stay silent all session.
    i=0
    while [ "$i" -lt 40 ]; do
        pw-dump 2>/dev/null | grep -qE '"node\.name": *"(alsa|bluez)_output' && return
        i=$((i + 1))
        sleep 0.25
    done
}

# startplasma-waylandsession lives in a distro-specific libexecdir (Arch uses
# /usr/lib, Fedora /usr/libexec): probe at runtime, and fail while the audio
# state is still untouched instead of starting a session that cannot end cleanly.
waylandsession=
for dir in /usr/lib /usr/libexec /usr/lib64/libexec /usr/lib/libexec; do
    if [ -x "$dir/startplasma-waylandsession" ]; then
        waylandsession="$dir/startplasma-waylandsession"
        break
    fi
done
if [ -z "$waylandsession" ]; then
    echo "xmb-bigscreen: startplasma-waylandsession not found in any known libexecdir" >&2
    exit 1
fi

cleanup() {
    # Both a signal trap and EXIT land here; the audio swap-back must run once.
    [ -n "${cleanup_done:-}" ] && return
    cleanup_done=1
    audio_state_exit
    stop_stale_inputhandlers
}
# Registered before audio_state_enter so a death mid-swap still unwinds; exit
# converges from any partial state because the parked desktop dir is the marker.
trap cleanup EXIT
# An unhandled signal kills sh without running the EXIT trap: route the session
# teardown signals through exit so cleanup still fires.
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

stop_stale_inputhandlers
audio_state_enter
audio_wait_ready

# Refresh the pad mappings for the controllers present at login: the search keys
# work out of the box, sticks swapped only if enabled in the XMB settings.
xmb-bigscreen-stick-swap >/dev/null 2>&1 || true

# Reuse Bigscreen's environment, then load our shell instead of the native one.
. plasma-bigscreen-common-env
export PLASMA_DEFAULT_SHELL=org.kde.plasma.xmbbigscreen

# Bigscreen force-shows the compositor keyboard regardless of KWin's visibility
# mode; drop the override, the mode is configured explicitly below.
unset KWIN_IM_SHOW_ALWAYS

# TV defaults regardless of the desktop's kwinrc: the [$i] locks apply only through
# this session's XDG_CONFIG_DIRS cascade; the shared ~/.config/kwinrc is untouched.
xmb_conf="${XDG_CONFIG_HOME:-$HOME/.config}/xmb-bigscreen"
mkdir -p "$xmb_conf"
cat > "$xmb_conf/kwinrc" <<'EOF'
[Desktops]
Number[$i]=1
Rows[$i]=1

[Windows]
ElectricBorders[$i]=0

[ElectricBorders]
Bottom[$i]=None
BottomLeft[$i]=None
BottomRight[$i]=None
Left[$i]=None
Right[$i]=None
Top[$i]=None
TopLeft[$i]=None
TopRight[$i]=None

[TouchEdges]
Bottom[$i]=none
Left[$i]=none
Right[$i]=none
Top[$i]=none

[Effect-overview]
BorderActivate[$i]=9

[Effect-windowview]
BorderActivate[$i]=9
BorderActivateAll[$i]=9

[TabBox]
BorderActivate[$i]=9
BorderAlternativeActivate[$i]=9

[Wayland]
VirtualKeyboardEnabled[$i]=true
VirtualKeyboardMode[$i]=2
EOF

# The lock screen is a dead end without a keyboard: never lock this session by
# itself, neither on idle nor when resuming from sleep.
cat > "$xmb_conf/kscreenlockerrc" <<'EOF'
[Daemon]
Autolock[$i]=false
LockOnResume[$i]=false
EOF

# Compositor keyboard (plasma-keyboard, if installed) for regular apps: compact,
# pad-navigable, shown when a text field activates. XMB fields bring their own.
cat > "$xmb_conf/plasmakeyboardrc" <<'EOF'
[General]
keyboardNavigationEnabled[$i]=true
panelFillScreenWidth[$i]=false
EOF

# Icon theme chosen in the XMB settings: pinned as an immutable key in the
# session-only cascade, so it beats the shared kdeglobals without touching it.
xmb_icons="$xmb_conf/icontheme"
rm -f "$xmb_conf/kdeglobals"
if [ -r "$xmb_icons" ]; then
    theme=$(head -n1 "$xmb_icons" 2>/dev/null | tr -cd 'A-Za-z0-9_.+-')
    [ -n "$theme" ] && printf '[Icons]\nTheme[$i]=%s\n' "$theme" > "$xmb_conf/kdeglobals"
fi
export XDG_CONFIG_DIRS="$xmb_conf:$XDG_CONFIG_DIRS"

startplasma-wayland --xwayland --libinput --exit-with-session="$waylandsession"
# Teardown belongs to the EXIT trap; hand the session's own exit code upward.
exit $?
